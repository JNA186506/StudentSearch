<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentSearch.NewStudentPage">
    <ContentPage.Content>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.ColumnSpan="2" Text="Edit Student"
                   FontSize="24" FontAttributes="Bold"/>

            <Label Grid.Row="1" Grid.Column="0" Text="Id"/>
            <Entry x:Name="IdEntry" Grid.Row="1" Grid.Column="1"/>

            <Label Grid.Row="2" Grid.Column="0" Text="Name"/>
            <Entry x:Name="NameEntry" Grid.Row="2" Grid.Column="1"/>

            <Label Grid.Row="3" Grid.Column="0" Text="Age"/>
            <Entry x:Name="AgeEntry" Grid.Row="3" Grid.Column="1"/>

            <Button x:Name="ChangeStudentButton" 
                    Grid.Row="4" Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="Save"
                    HorizontalOptions="End"
                    Clicked="OnSaveStudentClicked"/>
        </Grid>
    </ContentPage.Content> 
</ContentPage>