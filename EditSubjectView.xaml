<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentSearch.EditSubjectView">
    <ContentPage.Content>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <CollectionView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                            x:Name="StudentGradeCollection"
                            ItemsSource="{Binding }">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Coursecode}" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Grade1}" />
                            <Button Grid.Row="0" Grid.Column="2" Text="Delete Entry" Clicked="OnDeleteEntry" 
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="This student does not have any registered grades" />
                </CollectionView.EmptyView>
            </CollectionView>
            <Picker Grid.Column="0" Grid.Row="1"
                    x:Name="CoursePicker" 
                    ItemsSource="{Binding }" 
                    ItemDisplayBinding="{Binding Coursecode}"/>
            <Picker Grid.Column="1" Grid.Row="1"
                    x:Name="GradePicker" />
            <Button Grid.Column="2" Grid.Row="1" Text="Add Entry" Clicked="OnAddEntry" />
        </Grid>
    </ContentPage.Content>
</ContentPage>